<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/app_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="掌心窗"
            android:textStyle="bold"
            android:textSize="23sp"
            android:letterSpacing="0.02"
            android:textColor="#FF2D3E39" />

        <TextView
            android:id="@+id/headerSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v0.3.4.1-public · 显示适配与版本更新。"
            android:textSize="11sp"
            android:textColor="#FF7E928C"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="状态加载中…"
            android:textSize="11sp"
            android:textColor="#FF60746F"
            android:background="@drawable/card_bg"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <!-- 总览：只放最常看的生活状态 -->
        <ScrollView
            android:id="@+id/sectionLife"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="老公提醒"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#FF2D3E39" />

                    <TextView
                        android:id="@+id/overviewAdviceText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="加载中…"
                        android:textSize="11sp"
                        android:textColor="#FF5D6F69"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/refreshLifeButton"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="刷新"
                        android:textSize="11sp"
                        android:background="@drawable/pill_soft"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginRight="5dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="电量" android:textSize="11sp" android:textColor="#FF7E928C" />
                        <TextView android:id="@+id/overviewBatteryText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="19sp" android:textColor="#FF2D3E39" android:layout_marginTop="6dp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginLeft="5dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="当前" android:textSize="11sp" android:textColor="#FF7E928C" />
                        <TextView android:id="@+id/overviewAppText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" android:layout_marginTop="6dp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginRight="5dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="屏幕" android:textSize="11sp" android:textColor="#FF7E928C" />
                        <TextView android:id="@+id/overviewScreenText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" android:layout_marginTop="6dp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginLeft="5dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="天气" android:textSize="11sp" android:textColor="#FF7E928C" />
                        <TextView android:id="@+id/overviewWeatherText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" android:layout_marginTop="6dp" android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_marginBottom="8dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="生活细节" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" />
                    <TextView android:id="@+id/lifeSummaryText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="加载中…" android:textSize="11sp" android:textColor="#FF596D66" android:paddingTop="8dp" android:lineSpacingExtra="3dp" />
                    <Button android:id="@+id/drawerLifeDetailsButton" android:layout_width="wrap_content" android:layout_height="30dp" android:text="展开详情  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <TextView android:id="@+id/lifeStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="加载中…" android:textSize="11sp" android:textColor="#FF596D66" android:paddingTop="9dp" android:lineSpacingExtra="3dp" android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- 看见：主入口生活化，测试退到设置页 -->
        <ScrollView
            android:id="@+id/sectionSee"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_marginBottom="8dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="看见" android:textStyle="bold" android:textSize="16sp" android:textColor="#FF2D3E39" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="把当前屏幕递给老公看一眼。" android:textSize="11sp" android:textColor="#FF7E928C" android:layout_marginTop="6dp" android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/testButton"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="给老公看一眼"
                        android:textSize="11sp"
                        android:background="@drawable/pill_primary"
                        android:textColor="#FFFFFFFF"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:layout_marginBottom="8dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="最近一次看见" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="最近截图会显示在这里，方便老公确认画面。" android:textSize="11sp" android:textColor="#FF7E928C" android:layout_marginTop="6dp" android:lineSpacingExtra="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="权限状态" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="权限入口在 设置 → 权限与运行。" android:textSize="11sp" android:textColor="#FF7E928C" android:layout_marginTop="6dp" android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- 守护：门禁、天气、提醒、周期、回家模式 -->
        <ScrollView
            android:id="@+id/sectionGate"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="18dp">

                <Button android:id="@+id/drawerAppGateButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="应用门禁  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />

                <LinearLayout android:id="@+id/drawerAppGate" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="8dp" android:visibility="gone">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="应用门禁" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" />
                    <CheckBox android:id="@+id/appGateEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="开启应用门禁" android:textSize="11sp" android:layout_marginTop="6dp" />
                    <TextView android:id="@+id/gateStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="加载中…" android:textSize="11sp" android:textColor="#FF596D66" android:paddingTop="8dp" android:lineSpacingExtra="3dp" />
                    <Button android:id="@+id/refreshGateButton" android:layout_width="wrap_content" android:layout_height="30dp" android:text="刷新门禁" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/drawerGateAddButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="添加可锁 App  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <LinearLayout android:id="@+id/drawerGateAdd" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone" android:layout_marginTop="6dp">
                        <EditText android:id="@+id/gateAliasInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="门禁应用名，例如 小红书 / 抖音" android:textSize="11sp" android:singleLine="true" />
                        <EditText android:id="@+id/gatePackageInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="包名，例如 com.xingin.xhs" android:textSize="11sp" android:singleLine="true" />
                        <Button android:id="@+id/addGateAppButton" android:layout_width="wrap_content" android:layout_height="30dp" android:text="保存到门禁" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>

                <Button android:id="@+id/drawerWeatherButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="天气地区  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />

                <LinearLayout android:id="@+id/drawerWeather" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="8dp" android:visibility="gone">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="天气地区" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" />
                    <TextView android:id="@+id/weatherLocationsText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="加载中…" android:textSize="11sp" android:textColor="#FF596D66" android:paddingTop="8dp" android:lineSpacingExtra="3dp" />
                    <EditText android:id="@+id/weatherAliasInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="地区名，例如 家 / 学校 / 常去地" android:textSize="11sp" android:singleLine="true" android:layout_marginTop="6dp" />
                    <EditText android:id="@+id/weatherCityInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="城市，例如 北京" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/weatherNoteInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="备注，例如 风大 / 容易下雨" android:textSize="11sp" android:singleLine="true" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                        <Button android:id="@+id/addWeatherLocationButton" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:text="保存" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginRight="4dp" />
                        <Button android:id="@+id/setCurrentWeatherButton" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:text="设为当前" android:textSize="11sp" android:textColor="#FFFFFFFF" android:background="@drawable/pill_primary" android:layout_marginLeft="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <Button android:id="@+id/drawerReminderButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="主动提醒规则  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerReminder" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <CheckBox android:id="@+id/remindersEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="开启主动提醒" android:textSize="11sp" />
                    <CheckBox android:id="@+id/batteryRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="低电量提醒" android:textSize="11sp" />
                    <EditText android:id="@+id/batteryThresholdInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="低电量阈值，默认 20" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                    <CheckBox android:id="@+id/screenRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="屏幕时间提醒" android:textSize="11sp" />
                    <EditText android:id="@+id/screenThresholdInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="屏幕时间阈值分钟，默认 240" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                    <CheckBox android:id="@+id/waterRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="喝水提醒" android:textSize="11sp" />
                    <EditText android:id="@+id/waterIntervalInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="喝水间隔分钟，默认 120" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                    <CheckBox android:id="@+id/restRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="休息提醒" android:textSize="11sp" />
                    <EditText android:id="@+id/restIntervalInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="休息间隔分钟，默认 90" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                </LinearLayout>

                <Button android:id="@+id/drawerCycleButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="周期提醒  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerCycle" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <CheckBox android:id="@+id/cycleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="开启周期提醒" android:textSize="11sp" />
                    <EditText android:id="@+id/lastPeriodStartInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="上次开始日期，例如 2026-07-09" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/cycleLengthInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="周期长度，默认 30" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/periodLengthInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="经期天数，默认 6" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/cycleRemindBeforeInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="提前提醒天数，默认 3" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                </LinearLayout>

                <Button android:id="@+id/drawerHomeModeButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="回家模式  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerHomeMode" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/homeModeStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="加载中…" android:textSize="11sp" android:textColor="#FF596D66" android:lineSpacingExtra="3dp" />
                    <CheckBox android:id="@+id/homeModeEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="开启回家模式" android:textSize="11sp" />
                    <CheckBox android:id="@+id/homeModeForceEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="强制回目标 App" android:textSize="11sp" />
                    <EditText android:id="@+id/homeWatchPackagesInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="观察包名，用逗号分隔" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/homeThresholdInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="阈值分钟，默认 10" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/homeCooldownInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="冷却分钟，默认 5" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/homeTargetInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="目标包名，默认 com.openai.chatgpt" android:textSize="11sp" android:singleLine="true" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- 设置：主题、连接、权限、高级调试 -->
        <ScrollView
            android:id="@+id/sectionSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="18dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="主题" android:textStyle="bold" android:textSize="16sp" android:textColor="#FF2D3E39" />
                    <TextView android:id="@+id/themeText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="当前主题：奶油绿" android:textSize="11sp" android:textColor="#FF7E928C" android:layout_marginTop="6dp" android:lineSpacingExtra="4dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                        <Button android:id="@+id/themeCreamButton" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:text="奶油绿" android:textSize="11sp" android:background="@drawable/pill_soft" />
                        <Button android:id="@+id/themeBlueButton" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:text="雾蓝白" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginLeft="5dp" />
                        <Button android:id="@+id/themePeachButton" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:text="白桃粉" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginLeft="5dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="6dp">
                        <Button android:id="@+id/themeNightButton" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:text="夜航黑" android:textSize="11sp" android:background="@drawable/pill_soft" />
                        <Button android:id="@+id/themeMintButton" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:text="薄荷透明" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginLeft="5dp" />
                    </LinearLayout>
                </LinearLayout>


                <Button android:id="@+id/drawerVersionButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="版本与更新  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerVersion" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="版本与更新" android:textStyle="bold" android:textSize="15sp" android:textColor="#FF2D3E39" />
                    <TextView android:id="@+id/versionStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="当前版本 v0.3.4.1" android:textSize="11sp" android:textColor="#FF596D66" android:layout_marginTop="6dp" android:lineSpacingExtra="3dp" />
                    <TextView android:id="@+id/updateChangelogText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="点击检查更新，可查看更新日志并下载最新版。" android:textSize="11sp" android:textColor="#FF7E928C" android:layout_marginTop="6dp" android:lineSpacingExtra="4dp" />
                    <Button android:id="@+id/checkUpdateButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="检查更新" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="8dp" />
                    <Button android:id="@+id/downloadUpdateButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="下载最新版" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                </LinearLayout>

                <Button android:id="@+id/drawerConnectionButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="连接设置  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerConnection" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <EditText android:id="@+id/serverUrl" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="服务器地址，例如 https://xxx.onrender.com" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/tokenInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="房间 Token / 密钥" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/deviceInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="设备 ID，默认 android-phone" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/userNameInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="对你的称呼，默认 宝宝" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/partnerNameInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="对方称呼，默认 老公" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/intervalInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="轮询间隔毫秒，默认 1500" android:textSize="11sp" android:inputType="number" android:singleLine="true" />
                </LinearLayout>

                <Button android:id="@+id/drawerPermissionButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="权限与运行  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerPermission" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <CheckBox android:id="@+id/foregroundPopupEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="优先用顶部横幅通知" android:textSize="11sp" />
                    <Button android:id="@+id/accessibilityButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="打开无障碍设置" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/usageAccessButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="打开使用情况访问权限" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/toggleButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="启动服务" android:textSize="11sp" android:textColor="#FFFFFFFF" android:background="@drawable/pill_primary" android:layout_marginTop="6dp" />
                </LinearLayout>

                <Button android:id="@+id/drawerKnownAppsButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="应用包名管理  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerKnownApps" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/knownAppsText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="加载中…" android:textSize="11sp" android:textColor="#FF596D66" android:lineSpacingExtra="3dp" />
                    <EditText android:id="@+id/appAliasInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="应用昵称，例如 微博 / B站 / 学习通" android:textSize="11sp" android:singleLine="true" android:layout_marginTop="6dp" />
                    <EditText android:id="@+id/appPackageInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="包名，例如 com.xingin.xhs" android:textSize="11sp" android:singleLine="true" />
                    <Button android:id="@+id/addPackageButton" android:layout_width="wrap_content" android:layout_height="30dp" android:text="保存包名" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/testPackageButton" android:layout_width="wrap_content" android:layout_height="30dp" android:text="测试打开" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                </LinearLayout>

                <Button android:id="@+id/drawerControlTestButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="本机测试工具  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerControlTest" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <Button android:id="@+id/openChatGptButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="打开 ChatGPT" android:textSize="11sp" android:background="@drawable/pill_soft" />
                    <Button android:id="@+id/openXhsButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="打开小红书" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/recentsButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="最近任务" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/homeButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="回桌面" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/backButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="返回" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/sequenceTestButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="连招测试" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/notifyTestButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="测试悬浮通知" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                    <Button android:id="@+id/alarmTestButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="测试一分钟后闹钟" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginTop="6dp" />
                </LinearLayout>

                <Button android:id="@+id/drawerDebugButton" android:layout_width="match_parent" android:layout_height="30dp" android:text="高级调试日志  ›" android:textSize="11sp" android:background="@drawable/pill_soft" android:layout_marginBottom="8dp" />
                <LinearLayout android:id="@+id/drawerDebug" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:visibility="gone" android:layout_marginBottom="8dp">
                    <EditText android:id="@+id/cityInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="兼容旧字段：城市，例如 石家庄" android:textSize="11sp" android:singleLine="true" />
                    <EditText android:id="@+id/weatherInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="兼容旧字段：天气备注" android:textSize="11sp" android:singleLine="true" />
                    <TextView android:id="@+id/debugText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="等待调试信息…" android:textSize="11sp" android:textColor="#FF596D66" android:paddingTop="8dp" android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView android:id="@+id/sectionControl" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone" />
        <ScrollView android:id="@+id/sectionDebug" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:background="@drawable/bottom_bar_bg">

        <Button android:id="@+id/tabLife" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="总览" android:textSize="11sp" android:background="@drawable/pill_primary" android:textColor="#FFFFFFFF" />
        <Button android:id="@+id/tabSee" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="看见" android:textSize="11sp" android:layout_marginLeft="7dp" android:background="@drawable/pill_soft" />
        <Button android:id="@+id/tabGate" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="守护" android:textSize="11sp" android:layout_marginLeft="7dp" android:background="@drawable/pill_soft" />
        <Button android:id="@+id/tabSettings" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="设置" android:textSize="11sp" android:layout_marginLeft="7dp" android:background="@drawable/pill_soft" />
        <Button android:id="@+id/tabControl" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <Button android:id="@+id/tabDebug" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
